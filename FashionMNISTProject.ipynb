# Cell 18: Save Model and Final Output
print("\n" + "="*80)
print("STEP 16: SAVING MODEL AND FINALIZING")
print("="*80)

# Save the model
model.save('fashion_mnist_complete_model.h5')
print("\n💾 Model saved as: fashion_mnist_complete_model.h5")

# Also save in Keras format
model.save('fashion_mnist_complete_model.keras')
print("💾 Model saved as: fashion_mnist_complete_model.keras")

print("\n" + "="*80)
print("🎉 PROJECT COMPLETED SUCCESSFULLY!")
print("="*80)
print("\n✅ All steps completed with full outputs")
