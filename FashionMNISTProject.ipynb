# Cell 1: Install and Import Libraries
!pip install tensorflow scikit-learn seaborn matplotlib numpy -q

import numpy as np
import matplotlib.pyplot as plt
import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers
from sklearn.metrics import classification_report, confusion_matrix
import seaborn as sns
import warnings
warnings.filterwarnings('ignore')

print("✅ Libraries imported successfully")
print(f"TensorFlow version: {tf.__version__}")
print(f"NumPy version: {np.__version__}")

# Cell 2: Load Fashion MNIST Dataset
print("\n" + "="*60)
print("FASHION MNIST CLASSIFICATION PROJECT")
print("="*60)

# Load dataset
fashion_mnist = keras.datasets.fashion_mnist
(X_train_full, y_train_full), (X_test, y_test) = fashion_mnist.load_data()

# Class names
class_names = ['T-shirt/top', 'Trouser', 'Pullover', 'Dress', 'Coat',
               'Sandal', 'Shirt', 'Sneaker', 'Bag', 'Ankle boot']

# Display dataset info
print("\n📊 DATASET INFORMATION:")
print(f"Training images: {X_train_full.shape[0]}, shape: {X_train_full.shape[1:]} pixels")
print(f"Testing images: {X_test.shape[0]}, shape: {X_test.shape[1:]} pixels")
print(f"Number of classes: {len(class_names)}")
print(f"Classes: {class_names}")

# Cell 3: Preprocess Data
print("\n🔄 PREPROCESSING DATA...")

# Normalize pixel values
X_train_full = X_train_full.astype('float32') / 255.0
X_test = X_test.astype('float32') / 255.0

# Split training into train and validation sets (first 5000 for validation)
X_valid = X_train_full[:5000]
X_train = X_train_full[5000:]
y_valid = y_train_full[:5000]
y_train = y_train_full[5000:]

print(f"Training set: {X_train.shape}")
print(f"Validation set: {X_valid.shape}")
print(f"Test set: {X_test.shape}")
print("✓ Data normalized to [0, 1] range")

# Cell 4: Visualize Sample Images
print("\n🎨 VISUALIZING SAMPLE IMAGES...")

plt.figure(figsize=(15, 10))
for i in range(25):
    plt.subplot(5, 5, i+1)
    plt.xticks([])
    plt.yticks([])
    plt.grid(False)
    plt.imshow(X_train[i], cmap='gray')
    plt.xlabel(class_names[y_train[i]], fontsize=8)
plt.suptitle('Sample Fashion MNIST Training Images', fontsize=16, fontweight='bold')
plt.tight_layout()
plt.show()

# Cell 5: Build Neural Network Model
print("\n🏗️ BUILDING NEURAL NETWORK MODEL...")

model = keras.Sequential([
    layers.Flatten(input_shape=[28, 28], name="input_layer"),
    layers.Dense(300, activation='relu', name="hidden_layer_1"),
    layers.Dense(100, activation='relu', name="hidden_layer_2"),
    layers.Dense(10, activation='softmax', name="output_layer")
])

print("\n📋 MODEL ARCHITECTURE:")
model.summary()

# Cell 6: Compile Model
print("\n⚙️ COMPILING MODEL...")

model.compile(
    optimizer='adam',
    loss='sparse_categorical_crossentropy',
    metrics=['accuracy']
)

print("✓ Model compiled successfully")
print("  - Optimizer: Adam")
print("  - Loss: Sparse Categorical Crossentropy")
print("  - Metrics: Accuracy")

# Cell 7: Train Model
print("\n🏃 TRAINING MODEL...")
print("This will take 2-3 minutes...\n")

# Add early stopping to prevent overfitting
early_stopping = keras.callbacks.EarlyStopping(
    monitor='val_loss',
    patience=5,
    restore_best_weights=True,
    verbose=1
)

history = model.fit(
    X_train, y_train,
    epochs=30,
    validation_data=(X_valid, y_valid),
    callbacks=[early_stopping],
    verbose=1
)

# Cell 8: Plot Training History
print("\n📊 TRAINING HISTORY VISUALIZATION...")

fig, axes = plt.subplots(1, 2, figsize=(15, 5))

# Plot accuracy
axes[0].plot(history.history['accuracy'], 'b-', label='Training Accuracy', linewidth=2)
axes[0].plot(history.history['val_accuracy'], 'r-', label='Validation Accuracy', linewidth=2)
axes[0].set_title('Model Accuracy', fontsize=14, fontweight='bold')
axes[0].set_xlabel('Epochs')
axes[0].set_ylabel('Accuracy')
axes[0].legend()
axes[0].grid(True, alpha=0.3)

# Plot loss
axes[1].plot(history.history['loss'], 'b-', label='Training Loss', linewidth=2)
axes[1].plot(history.history['val_loss'], 'r-', label='Validation Loss', linewidth=2)
axes[1].set_title('Model Loss', fontsize=14, fontweight='bold')
axes[1].set_xlabel('Epochs')
axes[1].set_ylabel('Loss')
axes[1].legend()
axes[1].grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

# Cell 9: Evaluate on Test Set
print("\n🎯 TEST SET EVALUATION:")

test_loss, test_accuracy = model.evaluate(X_test, y_test, verbose=0)
print(f"Test Loss: {test_loss:.4f}")
print(f"Test Accuracy: {test_accuracy:.4f}")
print(f"Test Accuracy: {test_accuracy*100:.2f}%")

# Cell 10: Make Predictions
print("\n🔮 MAKING PREDICTIONS...")

y_pred_probs = model.predict(X_test, verbose=0)
y_pred = np.argmax(y_pred_probs, axis=1)

# Calculate accuracy
pred_accuracy = np.mean(y_pred == y_test)
print(f"Prediction Accuracy: {pred_accuracy:.4f} ({pred_accuracy*100:.2f}%)")

# Cell 11: Display Sample Predictions
print("\n📸 SAMPLE PREDICTIONS:")

plt.figure(figsize=(20, 10))
for i in range(25):
    plt.subplot(5, 5, i+1)
    plt.xticks([])
    plt.yticks([])
    plt.grid(False)
    plt.imshow(X_test[i], cmap='gray')
    
    true_label = class_names[y_test[i]]
    pred_label = class_names[y_pred[i]]
    confidence = y_pred_probs[i][y_pred[i]] * 100
    
    color = 'green' if y_test[i] == y_pred[i] else 'red'
    plt.xlabel(f"True: {true_label[:10]}\nPred: {pred_label[:10]}\nConf: {confidence:.1f}%", 
              color=color, fontsize=8)
plt.suptitle('Predictions on Test Images (Green=Correct, Red=Incorrect)', 
             fontsize=16, fontweight='bold')
plt.tight_layout()
plt.show()

# Cell 12: Classification Report
print("\n📋 CLASSIFICATION REPORT:")
print("="*70)

report = classification_report(y_test, y_pred, target_names=class_names)
print(report)

# Cell 13: Confusion Matrix
print("\n📊 CONFUSION MATRIX:")

plt.figure(figsize=(12, 10))
cm = confusion_matrix(y_test, y_pred)
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
            xticklabels=class_names, yticklabels=class_names)
plt.title('Confusion Matrix', fontsize=16, fontweight='bold')
plt.xlabel('Predicted Label', fontsize=12)
plt.ylabel('True Label', fontsize=12)
plt.xticks(rotation=45, ha='right')
plt.yticks(rotation=0)
plt.tight_layout()
plt.show()

# Per-class accuracy
print("\nPer-class Accuracy:")
for i, class_name in enumerate(class_names):
    class_mask = (y_test == i)
    if np.sum(class_mask) > 0:
        class_acc = np.mean(y_pred[class_mask] == y_test[class_mask])
        print(f"  {class_name:15s}: {class_acc:.4f} ({class_acc*100:.2f}%)")

# Cell 14: Analyze Misclassifications
print("\n🔍 MISCLASSIFICATION ANALYSIS:")

misclassified = np.where(y_pred != y_test)[0]
print(f"Total misclassified: {len(misclassified)} out of {len(y_test)}")
print(f"Error rate: {len(misclassified)/len(y_test)*100:.2f}%")

if len(misclassified) > 0:
    print("\n📸 Sample Misclassifications:")
    plt.figure(figsize=(15, 10))
    for i, idx in enumerate(misclassified[:12]):
        plt.subplot(3, 4, i+1)
        plt.xticks([])
        plt.yticks([])
        plt.grid(False)
        plt.imshow(X_test[idx], cmap='gray')
        
        true_label = class_names[y_test[idx]]
        pred_label = class_names[y_pred[idx]]
        confidence = y_pred_probs[idx][y_pred[idx]] * 100
        
        plt.title(f"True: {true_label[:8]}\nPred: {pred_label[:8]}\nConf: {confidence:.1f}%", 
                 fontsize=9, color='red')
    plt.suptitle("Examples of Misclassified Images", fontsize=16, fontweight='bold')
    plt.tight_layout()
    plt.show()

# Cell 15: Model Performance Summary
print("\n" + "="*70)
print("🎯 MODEL PERFORMANCE SUMMARY")
print("="*70)

final_epoch = len(history.history['accuracy'])
print(f"Total epochs trained: {final_epoch}")
print(f"Final training accuracy: {history.history['accuracy'][-1]:.4f} ({history.history['accuracy'][-1]*100:.2f}%)")
print(f"Final validation accuracy: {history.history['val_accuracy'][-1]:.4f} ({history.history['val_accuracy'][-1]*100:.2f}%)")
print(f"Test accuracy: {test_accuracy:.4f} ({test_accuracy*100:.2f}%)")
print(f"\nFinal training loss: {history.history['loss'][-1]:.4f}")
print(f"Final validation loss: {history.history['val_loss'][-1]:.4f}")
print(f"Test loss: {test_loss:.4f}")

# Check overfitting
if history.history['val_accuracy'][-1] < history.history['accuracy'][-1] - 0.05:
    print("\n⚠️ Warning: Model might be overfitting")
else:
    print("\n✅ Model generalizes well (no significant overfitting)")
print("="*70)

# Cell 16: Save Model
print("\n💾 SAVING MODEL...")

# Save in multiple formats
model.save('fashion_mnist_model.h5')
model.save('fashion_mnist_model.keras')
print("✓ Model saved successfully")
print("  - fashion_mnist_model.h5")
print("  - fashion_mnist_model.keras")

# Cell 17: Single Image Prediction Demo
print("\n🎲 SINGLE IMAGE PREDICTION DEMO:")

# Pick random test image
random_idx = np.random.randint(0, len(X_test))
test_image = X_test[random_idx]
true_label = class_names[y_test[random_idx]]

# Make prediction
test_image_reshaped = test_image.reshape(1, 28, 28)
pred_probs = model.predict(test_image_reshaped, verbose=0)[0]
pred_class = np.argmax(pred_probs)
pred_label = class_names[pred_class]
confidence = pred_probs[pred_class] * 100

# Display results
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 5))

ax1.imshow(test_image, cmap='gray')
ax1.set_title(f"Test Image\nTrue Label: {true_label}", fontsize=14, fontweight='bold')
ax1.axis('off')

colors = ['skyblue'] * 10
colors[pred_class] = 'green' if pred_class == y_test[random_idx] else 'red'
bars = ax2.barh(class_names, pred_probs * 100, color=colors)
ax2.set_xlabel('Confidence (%)')
ax2.set_title(f"Prediction: {pred_label}\nConfidence: {confidence:.1f}%", 
              fontsize=14, fontweight='bold')
ax2.set_xlim(0, 100)

plt.tight_layout()
plt.show()

print(f"\nPrediction Result:")
print(f"  True Label: {true_label}")
print(f"  Predicted: {pred_label}")
print(f"  Confidence: {confidence:.2f}%")
print(f"  Correct: {'✅ Yes' if pred_class == y_test[random_idx] else '❌ No'}")

# Cell 18: Final Conclusion
print("\n" + "="*70)
print("🎉 PROJECT COMPLETED SUCCESSFULLY!")
print("="*70)
print("\nKey Achievements:")
print("✓ Successfully loaded and preprocessed Fashion MNIST dataset")
print("✓ Built neural network with 3 hidden layers")
print("✓ Trained model for 10-class clothing classification")
print(f"✓ Achieved test accuracy of {test_accuracy*100:.2f}%")
print("✓ Generated comprehensive visualizations and metrics")
print("✓ Analyzed model performance and misclassifications")
print("\n✨ This completes the Fashion MNIST classification project!")
print("="*70)
